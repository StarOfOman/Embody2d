# ══════════════════════════════════════════════════════════════
#  Live2D Avatar Stack — Environment Configuration
#  Compatible with Unreal_Vtuber orchestrator pipeline
# ══════════════════════════════════════════════════════════════

# ── Ports (match Unreal_Vtuber defaults) ─────────────────────
VTUBER_FRONTEND_PORT=3000
VTUBER_API_PORT=4000
VTUBER_SCRIPT_RUNNER_PORT=9877
ORCHESTRATOR_HEALTH_PORT=9090
VTUBER_STREAM_PORT=8554

# ── Agent API Server ─────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Frontend ─────────────────────────────────────────────────
VITE_WS_URL=ws://localhost:4000
VITE_API_URL=http://localhost:4000

# ── LLM (llama.cpp — Unreal_Vtuber compatible) ──────────────
LLM_PORT=8081
LLM_URL=http://vtuber-llama-server:8081
LLM_API_KEY=
LLM_MODEL=default
LLM_MODEL_PATH=./models
LLM_MODEL_FILE=model.gguf
LLM_MEMORY_LIMIT=3g
SYSTEM_PROMPT=You are a friendly avatar assistant. Keep responses concise — 1-3 sentences.

# ── TTS (Kokoro — GPU accelerated) ──────────────────────────
TTS_PORT=8880
TTS_URL=http://vtuber-kokoro-tts:8880
TTS_VOICE=af_sarah
TTS_MODEL=kokoro

# ── TTS (ElevenLabs — cloud, per-character override) ─────────
ELEVENLABS_API_KEY=

# Available Kokoro voices:
#   American Female: af_alloy, af_bella, af_jessica, af_nicole, af_nova,
#                    af_river, af_sarah, af_sky, af_aoede, af_kore
#   American Male:   am_adam, am_echo, am_eric, am_fenrir, am_liam,
#                    am_michael, am_onyx, am_puck
#   British Female:  bf_alice, bf_emma, bf_isabella, bf_lily
#   British Male:    bm_daniel, bm_fable, bm_george, bm_lewis

# ── Script Runner (Unreal_Vtuber compat) ─────────────────────
RUNNER_API_TOKEN=
VTUBER_ALLOWED_ADDRESSES=127.0.0.1,::1,172.17.0.1,172.18.0.1
VTUBER_SESSION_ROOT=/opt/embody/sessions
VTUBER_AUDIO_HOLD_MS=15000

# ── Health Monitor (Unreal_Vtuber compat) ────────────────────
MONITORED_SERVICES=vtuber-live2d-frontend,vtuber-live2d-api,vtuber-live2d-streamer,vtuber-kokoro-tts
MIN_UPTIME_REQUIRED=80.0

# ── GPU Config ───────────────────────────────────────────────
NVIDIA_DRIVER_CAPABILITIES=all
NVIDIA_VISIBLE_DEVICES=all

# ── Orchestrator Identity (set by provisioning) ─────────────
# ORCHESTRATOR_ID=
# ORCHESTRATOR_ADDRESS=
# ORCHESTRATOR_CAPABILITY=live2d

# ── Optional: Streaming override ─────────────────────────────
# AVATAR_URL=http://live2d-frontend:3000
# STREAM_OUT=rtsp://0.0.0.0:8554/live
